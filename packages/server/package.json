    "@fastify/websocket": "^10.0.1",
    "@rekha/shared": "workspace:*",
    "argon2": "^0.40.3",
    "better-sqlite3": "^11.1.2",
    "fastify": "^4.28.1",
    "pino": "^9.3.2",
    "pm2": "^5.4.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
